# 复制为 .env 并填入真实值(.env 已被 .gitignore 排除,不会提交)。
# scripts/start-all.sh 启动时自动加载;IDE 里跑单个服务需在 Run Configuration 配置同名环境变量。
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your-mysql-password

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

KAFKA_SERVERS=localhost:9092

# 通知邮件用的 SMTP 账号(QQ 邮箱为"授权码",不是登录密码);不配则邮件功能失败,其余功能不受影响
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-smtp-auth-code

MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ---- 以下仅 docker compose 部署时使用(本地裸跑脚本不读) ----
# 浏览器访问用的公网主机:EC2 上填弹性 IP 或域名
PUBLIC_HOST=localhost
# 前端对外端口(EC2 上用 80)
FRONTEND_PORT=80
# MinIO 对外端口(预签名音频 URL 直连;EC2 安全组需放行)
MINIO_PUBLIC_PORT=9000
