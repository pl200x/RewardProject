<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.Music_management.mapper.UserMapper">
    <!--  根据用户ID查询用户  -->
    <select id="queryById">
        SELECT * FROM user WHERE id = #{id}
    </select>

    <select id="findAllUserByIds">
        SELECT * FROM user WHERE id in
        <foreach item="id" collection="ids" open ="(" separator="," close =")">
            #{id}
        </foreach>
    </select>

        <select id="queryByName">
            SELECT * FROM user WHERE name = #{name}
        </select>

        <select id="add">
            insert into user(name, password, age, gender,email, job, interest, avatar)
            values
            (#{name}, #{password}, #{age}, #{gender},#{email}, #{job}, #{interest}, #{avatar})
        </select>

    <select id="updateInterest">
        update user set interest = #{interest} WHERE id = #{id}
    </select>

    <select id="updateAvatar">
        update user set avatar = #{avatar} WHERE id = #{id}
    </select>


    <!--    <select id="deleteUser">-->
    <!--        delete from user where id = #{id}-->
    <!--    </select>-->
</mapper>