<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.Multi_reward.mapper.PlayRecordMapper">
    <resultMap id="PlayRecordResultMap" type="com.example.Multi_reward.entity.PlayRecord">
        <id property="id" column="id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="userId" column="user_id"/>
        <result property="musicId" column="music_id"/>
        <result property="duration" column="duration"/>
        <result property="syncTime" column="sync_time"/>
    </resultMap>
    <!--  根据用户ID查询用户  -->
    <select id="queryById" resultMap="PlayRecordResultMap">
        SELECT * FROM playrecord WHERE id = #{id}
    </select>

    <select id="queryByDate" resultMap="PlayRecordResultMap" >
        SELECT * FROM playrecord WHERE user_id = #{userId} AND sync_time BETWEEN #{startTime} AND #{endTime}
    </select>

<!--    <select id="queryByName" resultMap="PlayRecordResultMap">-->
<!--        SELECT * FROM user WHERE name = #{name}-->
<!--    </select>-->

    <select id="addRecord" resultMap="PlayRecordResultMap">
        insert into playrecord(create_time, update_time, user_id, music_id, duration, sync_time)
        values
        (now(), now(), #{userId}, #{musicId},#{duration}, #{syncTime})
    </select>

<!--    <select id="updateInterest" resultMap="PlayRecordResultMap">-->
<!--        update user set interest = #{interest} WHERE id = #{id}-->
<!--    </select>-->


    <!--    <select id="deleteUser">-->
    <!--        delete from user where id = #{id}-->
    <!--    </select>-->
</mapper>